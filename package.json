{
  "name": "@agegr/pi-web",
  "version": "0.6.12",
  "description": "Web UI for the pi coding agent",
  "license": "MIT",
  "author": "agegr",
  "main": "electron/dist/main.js",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 30141",
    "build": "next build --webpack",
    "start": "node --require ./preload.js node_modules/next/dist/bin/next start -p 30141",
    "lint": "eslint .",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dev:electron": "npm run build:electron && npx electron .",
    "pack": "npm run build && npm run build:electron && npx @electron/rebuild && npx electron-builder --dir",
    "dist": "npm run build && npm run build:electron && npx @electron/rebuild && npx electron-builder"
  },
  "build": {
    "extends": "electron-builder.yml"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@lobehub/icons": "^5.6.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "katex": "^0.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.1",
    "next-intl": "^4.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "typescript": "5.9.3"
  }
}
